{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/webhook",
      "destination": "/api/webhook.ts"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "runtime": "vercel-node@latest"
    }
  },
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 9 * * *"
    }
  ]
}
